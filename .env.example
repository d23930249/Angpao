# --- App ---
NEXT_PUBLIC_APP_NAME="Stellar Starter"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Landing-page "View on GitHub" link. Defaults to https://github.com/.
NEXT_PUBLIC_REPO_URL="https://github.com/"

# --- Postgres ---
DRIZZLE_DATABASE_URL="postgres://postgres:postgres@localhost:5432/stellar_starter"

# --- Stellar (Testnet by default) ---
# To go to MAINNET, flip all FOUR of these together (server + client) and
# re-deploy the contract on mainnet (see contracts/scripts/deploy.sh):
#   STELLAR_NETWORK=public
#   NEXT_PUBLIC_STELLAR_NETWORK=public
#   STELLAR_HORIZON_URL=https://horizon.stellar.org
#   STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
#   SOROBAN_RPC_URL=https://mainnet.sorobanrpc.com   (or your own provider)
STELLAR_NETWORK="testnet"
# Network the CLIENT renders for (explorer links + network badge). Keep in sync
# with STELLAR_NETWORK: testnet | public | futurenet.
NEXT_PUBLIC_STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# --- Auth ---
SESSION_SECRET="change-me-min-32-chars-random-base64"
SESSION_COOKIE_NAME="stellar_session"
SESSION_TTL_SECONDS="604800"
NONCE_TTL_SECONDS="300"

# --- Merchant Payment Hub ---
# Defaults are fine for the demo; tune to taste.
INVOICE_DEFAULT_TTL_SECONDS="900"
INVOICE_AMOUNT_MINOR_MAX="10000000000"
PAYMENT_DETECTION_INTERVAL_MS="5000"
PAYMENT_AUTO_PAY_DELAY_MS="10000"
SETTLEMENT_AFTER_PAY_DELAY_MS="5000"
# When true (or NODE_ENV !== "production"), the /simulate-* endpoints are mounted.
DEMO_MODE="true"

# --- i18n ---
NEXT_PUBLIC_SUPPORTED_LOCALES="en,vi"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_LOCALE_PREFIX="as-needed"

# --- Universal Merchant Payment Hub ---
# Optional: separate HMAC key for signed invoice ids. Falls back to SESSION_SECRET.
# SIGNED_ID_SECRET=""
# Optional: separate HS256 secret for the customer JWT (issued by
# /api/checkout/verify). Falls back to SIGNED_ID_SECRET, then SESSION_SECRET.
# CUSTOMER_JWT_SECRET=""
INVOICE_DEFAULT_TTL_SECONDS="900"
INVOICE_AMOUNT_MINOR_MAX="10000000000"
WITHDRAWAL_DEFAULT_TTL_SECONDS="1800"
# "mock" = in-app mock anchor (no external account needed).
# Otherwise set to a real anchor domain, e.g. "anchorusd.com".
OFFRAMP_ANCHOR_DOMAIN="mock"
OFFRAMP_POLL_INTERVAL_MS="10000"
HORIZON_STREAM_ENABLED="true"
SSE_HEARTBEAT_MS="15000"
SSE_MAX_CONCURRENT_PER_IP="20"
IDEMPOTENCY_TTL_SECONDS="86400"
DEMO_MODE="false"

# --- USDC asset ---
USDC_ASSET_CODE="USDC"
USDC_ASSET_ISSUER_TESTNET="GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5"
USDC_ASSET_ISSUER_PUBLIC="GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN"

# --- Soroban escrow contract (optional; enables /api/escrow/*) ---
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
# Deployed AngpaoEscrow contract id. See contracts/DEPLOYMENT.md.
SOROBAN_ESCROW_CONTRACT_ID=""
# USDC Stellar Asset Contract (SAC) id (legacy fallback for the escrow token).
USDC_SAC_CONTRACT_ID=""
# SAC of the asset escrowed by /api/escrow/*. Defaults to USDC_SAC_CONTRACT_ID.
# On testnet, set to the native XLM SAC so any friendbot-funded wallet works.
ESCROW_TOKEN_CONTRACT_ID=""
ESCROW_ASSET_CODE="XLM"
ESCROW_ASSET_DECIMALS="7"
